{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "build",
      "type": "shell",
      "command": "dotnet",
      "args": [
        "build",
        "src/PhotoCopyHub.Web/PhotoCopyHub.Web.csproj"
      ],
      "group": "build",
      "problemMatcher": "$msCompile"
    },
    {
      "label": "Run PhotoCopyHub (watch)",
      "type": "shell",
      "command": "dotnet",
      "args": [
        "watch",
        "run"
      ],
      "options": {
        "cwd": "${workspaceFolder}/src/PhotoCopyHub.Web"
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      },
      "problemMatcher": "$msCompile"
    }
  ]
}

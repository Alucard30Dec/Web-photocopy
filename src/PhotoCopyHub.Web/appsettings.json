{
  "DatabaseProvider": "Sqlite",
  "Database": {
    "UseSqliteFallbackWhenPrimaryUnavailable": false,
    "PrimaryConnectTimeoutMs": 3000
  },
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=photocopyhub.db",
    "FallbackSqliteConnection": "Data Source=photocopyhub.fallback.db"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Business": {
    "ShippingFee": 15000,
    "TopUpRequireAdminApprovalThreshold": 2000000,
    "RefundRequireAdminApprovalThreshold": 1000000
  },
  "FileStorage": {
    "RootPath": "App_Data/uploads",
    "MaxFileSizeMb": 20,
    "AllowedExtensions": [ ".pdf", ".jpg", ".jpeg", ".png", ".doc", ".docx", ".xls", ".xlsx", ".ppt", ".pptx" ],
    "AllowedMimeTypes": [
      "application/pdf",
      "image/jpeg",
      "image/png",
      "application/msword",
      "application/vnd.openxmlformats-officedocument.wordprocessingml.document",
      "application/vnd.ms-excel",
      "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet",
      "application/vnd.ms-powerpoint",
      "application/vnd.openxmlformats-officedocument.presentationml.presentation"
    ]
  },
  "SeedAdmin": {
    "Email": "admin@photocopyhub.local",
    "Password": "Admin@123456",
    "FullName": "Quản trị hệ thống"
  },
  "SeedShopOperator": {
    "Email": "operator@photocopyhub.local",
    "Password": "Operator@123456",
    "FullName": "Nhân viên vận hành"
  },
  "TopUpInfo": {
    "BankName": "Vietcombank",
    "AccountNumber": "0123456789",
    "AccountName": "NGUYEN VAN A",
    "TransferContentPrefix": "TOPUP"
  },
  "SeedSampleData": {
    "Enabled": false
  }
}

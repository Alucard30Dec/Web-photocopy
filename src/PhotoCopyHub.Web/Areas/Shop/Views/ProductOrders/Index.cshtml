@model List<ProductOrder>
@{
    ViewData["Title"] = "Đơn văn phòng phẩm";
}

<section class="page-hero mb-3">
    <h3 class="mb-2">Đơn văn phòng phẩm</h3>
    <p class="mb-0">Theo dõi và cập nhật trạng thái xử lý cho các đơn mua sản phẩm.</p>
</section>

<div class="table-responsive">
    <table class="table table-striped align-middle">
        <thead>
        <tr>
            <th>Mã đơn</th>
            <th>Khách hàng</th>
            <th>Tổng tiền</th>
            <th>Trạng thái hiện tại</th>
            <th>Cập nhật</th>
        </tr>
        </thead>
        <tbody>
        @if (Model.Count == 0)
        {
            <tr>
                <td colspan="5" class="text-center text-muted py-4">Không có đơn văn phòng phẩm nào.</td>
            </tr>
        }
        else
        {
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.Id</td>
                    <td>@item.User?.Email</td>
                    <td>@item.TotalAmount.ToString("N0")</td>
                    <td><span class="badge @item.Status.ToBadgeClass()">@item.Status.GetDisplayName()</span></td>
                    <td>
                        <form asp-action="UpdateStatus" method="post" class="d-flex flex-wrap gap-1">
                            <input type="hidden" name="OrderId" value="@item.Id" />
                            <select name="Status" class="form-select form-select-sm">
                                @foreach (var status in Enum.GetValues<OrderStatus>())
                                {
                                    if (status == item.Status)
                                    {
                                        <option selected value="@status">@status.GetDisplayName()</option>
                                    }
                                    else
                                    {
                                        <option value="@status">@status.GetDisplayName()</option>
                                    }
                                }
                            </select>
                            <input type="text" name="Note" class="form-control form-control-sm" placeholder="Ghi chú" />
                            <button type="submit" class="btn btn-sm btn-primary">Lưu</button>
                        </form>
                    </td>
                </tr>
            }
        }
        </tbody>
    </table>
</div>

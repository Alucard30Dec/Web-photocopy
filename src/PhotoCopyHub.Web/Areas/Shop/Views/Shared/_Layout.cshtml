<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Shop - PhotoCopyHub</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:wght@400;500;600;700&family=Plus+Jakarta+Sans:wght@600;700;800&display=swap" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
@{
    var shopController = ViewContext.RouteData.Values["controller"]?.ToString() ?? string.Empty;
}
<nav class="navbar navbar-expand-lg navbar-dark admin-topbar">
    <div class="container-fluid">
        <a class="navbar-brand admin-title" asp-area="Shop" asp-controller="Dashboard" asp-action="Index">PhotoCopyHub Vận Hành</a>
        <div class="d-flex gap-2">
            <a class="btn btn-outline-light btn-sm rounded-pill px-3" asp-area="" asp-controller="Home" asp-action="Index">Về trang chính</a>
        </div>
    </div>
</nav>

<div class="container-fluid admin-shell">
    <div class="row">
        <aside class="col-lg-2 mb-3 admin-sidebar">
            <div class="list-group admin-menu">
                <a class="list-group-item list-group-item-action @(shopController == "Dashboard" ? "active" : string.Empty)" asp-area="Shop" asp-controller="Dashboard" asp-action="Index">Dashboard</a>
                <a class="list-group-item list-group-item-action @(shopController == "TopUpRequests" ? "active" : string.Empty)" asp-area="Shop" asp-controller="TopUpRequests" asp-action="Index">Duyệt nạp tiền</a>
                <a class="list-group-item list-group-item-action @(shopController == "TopUpRequests" ? "active" : string.Empty)" asp-area="Shop" asp-controller="TopUpRequests" asp-action="CounterTopUp">Nạp tiền tại quầy</a>
                <a class="list-group-item list-group-item-action @(shopController == "PrintJobs" ? "active" : string.Empty)" asp-area="Shop" asp-controller="PrintJobs" asp-action="Index">Hàng chờ in</a>
                <a class="list-group-item list-group-item-action @(shopController == "ProductOrders" ? "active" : string.Empty)" asp-area="Shop" asp-controller="ProductOrders" asp-action="Index">Đơn văn phòng phẩm</a>
                <a class="list-group-item list-group-item-action @(shopController == "SupportOrders" ? "active" : string.Empty)" asp-area="Shop" asp-controller="SupportOrders" asp-action="Index">Đơn dịch vụ hỗ trợ</a>
                <a class="list-group-item list-group-item-action @(shopController == "Inventory" ? "active" : string.Empty)" asp-area="Shop" asp-controller="Inventory" asp-action="Index">Quản lý tồn kho</a>
            </div>
        </aside>

        <main class="col-lg-10">
            <partial name="~/Views/Shared/_Alert.cshtml" />
            @RenderBody()
        </main>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>

@model List<Product>
@{
    ViewData["Title"] = "Dashboard vận hành";
}

<section class="page-hero mb-3">
    <h3 class="mb-2">Dashboard vận hành tiệm photocopy</h3>
    <p class="mb-0">Theo dõi nhanh các hàng chờ xử lý để vận hành tiệm mượt và đúng SLA.</p>
</section>

<div class="row g-3 mb-3">
    <div class="col-md-4">
        <div class="stat-card">
            <div class="stat-label">Top-up chờ kiểm tra</div>
            <div class="stat-value">@ViewBag.PendingTopUp</div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="stat-card">
            <div class="stat-label">Top-up chờ Admin bước 2</div>
            <div class="stat-value">@ViewBag.PendingAdminTopUp</div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="stat-card">
            <div class="stat-label">Hàng chờ in</div>
            <div class="stat-value">@ViewBag.PrintQueue</div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="stat-card">
            <div class="stat-label">Đơn văn phòng phẩm chờ xử lý</div>
            <div class="stat-value">@ViewBag.ProductOrdersWaiting</div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="stat-card">
            <div class="stat-label">Đơn dịch vụ hỗ trợ chờ xử lý</div>
            <div class="stat-value">@ViewBag.SupportOrdersWaiting</div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="stat-card">
            <div class="stat-label">Sản phẩm sắp hết (<=10)</div>
            <div class="stat-value">@ViewBag.LowStockProducts</div>
        </div>
    </div>
</div>

<div class="card">
    <div class="card-header">Danh sách cảnh báo tồn kho</div>
    <div class="table-responsive">
        <table class="table table-striped">
            <thead>
            <tr>
                <th>Sản phẩm</th>
                <th>Tồn kho</th>
                <th>Giá</th>
            </tr>
            </thead>
            <tbody>
            @if (Model.Count == 0)
            {
                <tr>
                    <td colspan="3" class="text-center text-muted py-4">Không có sản phẩm nào sắp hết.</td>
                </tr>
            }
            else
            {
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.Name</td>
                        <td>@item.StockQuantity</td>
                        <td>@item.Price.ToString("N0")</td>
                    </tr>
                }
            }
            </tbody>
        </table>
    </div>
</div>

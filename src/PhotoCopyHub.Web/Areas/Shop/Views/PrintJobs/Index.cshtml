@model List<PrintJob>
@{
    ViewData["Title"] = "Hàng chờ in";
}

<section class="page-hero mb-3">
    <h3 class="mb-2">Hàng chờ in</h3>
    <p class="mb-2">Tiếp nhận đơn từ khách, xác nhận file và chuyển trạng thái theo tiến độ thực tế tại tiệm.</p>
    <div class="info-chip-group">
        <span class="info-chip">Tổng đơn: @Model.Count</span>
        <span class="info-chip">Chờ xác nhận: @Model.Count(x => x.Status == PrintJobStatus.Submitted)</span>
        <span class="info-chip">Đang in: @Model.Count(x => x.Status == PrintJobStatus.Processing)</span>
    </div>
</section>

<div class="table-responsive">
    <table class="table table-striped">
        <thead>
        <tr>
            <th>Mã đơn</th>
            <th>Khách hàng</th>
            <th>Thông số in</th>
            <th>Tổng tiền</th>
            <th>Trạng thái</th>
            <th>Ngày tạo</th>
            <th></th>
        </tr>
        </thead>
        <tbody>
        @if (Model.Count == 0)
        {
            <tr>
                <td colspan="7" class="text-center text-muted py-4">Không có đơn in nào.</td>
            </tr>
        }
        else
        {
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.Id</td>
                    <td>@item.User?.Email</td>
                    <td>
                        @item.PaperSize.GetDisplayName() · @item.PrintSide.GetDisplayName()
                        <div class="text-muted small">@item.Copies bản x @item.TotalPages trang</div>
                    </td>
                    <td>@item.TotalAmount.ToString("N0")</td>
                    <td><span class="badge @item.Status.ToBadgeClass()">@item.Status.GetDisplayName()</span></td>
                    <td>@item.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</td>
                    <td>
                        <div class="d-flex flex-wrap gap-2">
                            <a class="btn btn-sm btn-outline-primary" asp-action="Details" asp-route-id="@item.Id">Chi tiết</a>
                        </div>
                    </td>
                </tr>
            }
        }
        </tbody>
    </table>
</div>

@model List<SupportService>
@{
    ViewData["Title"] = "Quản lý dịch vụ hỗ trợ";
}

<div class="d-flex justify-content-end mb-3">
    <a class="btn btn-primary" asp-action="Edit">Thêm dịch vụ</a>
</div>

<div class="table-responsive">
    <table class="table table-striped bg-white">
        <thead>
            <tr>
                <th>Tên</th>
                <th>Đơn giá</th>
                <th>Kiểu tính phí</th>
                <th>Trạng thái</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Name</td>
                <td>@item.UnitPrice.ToString("N0")</td>
                <td>@item.FeeType</td>
                <td>@(item.IsActive ? "Active" : "Inactive")</td>
                <td><a class="btn btn-sm btn-outline-primary" asp-action="Edit" asp-route-id="@item.Id">Sửa</a></td>
            </tr>
        }
        </tbody>
    </table>
</div>

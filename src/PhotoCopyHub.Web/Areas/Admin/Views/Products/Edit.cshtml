@model EditProductViewModel
@{
    ViewData["Title"] = "Sản phẩm";
}

<div class="card">
    <div class="card-body">
        <h4>@(Model.Id.HasValue ? "Cập nhật" : "Thêm") sản phẩm</h4>
        <form asp-action="Edit" method="post">
            <input asp-for="Id" type="hidden" />
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="mb-3"><label asp-for="Name" class="form-label"></label><input asp-for="Name" class="form-control" /><span asp-validation-for="Name" class="text-danger"></span></div>
            <div class="mb-3"><label asp-for="Description" class="form-label"></label><textarea asp-for="Description" class="form-control"></textarea></div>
            <div class="mb-3"><label asp-for="Price" class="form-label"></label><input asp-for="Price" class="form-control" /></div>
            <div class="mb-3"><label asp-for="StockQuantity" class="form-label"></label><input asp-for="StockQuantity" class="form-control" /></div>
            <div class="mb-3"><label asp-for="ImageUrl" class="form-label"></label><input asp-for="ImageUrl" class="form-control" /></div>
            <div class="form-check mb-3"><input asp-for="IsActive" class="form-check-input" /><label asp-for="IsActive" class="form-check-label"></label></div>

            <button class="btn btn-primary" type="submit">Lưu</button>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="~/Views/Shared/_ValidationScriptsPartial.cshtml" />
}

@model List<Product>
@{
    ViewData["Title"] = "Quản lý văn phòng phẩm";
}

<div class="d-flex justify-content-end mb-3">
    <a class="btn btn-primary" asp-action="Edit">Thêm sản phẩm</a>
</div>

<div class="table-responsive">
    <table class="table table-striped bg-white">
        <thead>
            <tr>
                <th>Tên</th>
                <th>Giá</th>
                <th>Tồn kho</th>
                <th>Trạng thái</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Name</td>
                <td>@item.Price.ToString("N0")</td>
                <td>@item.StockQuantity</td>
                <td>@(item.IsActive ? "Active" : "Inactive")</td>
                <td><a class="btn btn-sm btn-outline-primary" asp-action="Edit" asp-route-id="@item.Id">Sửa</a></td>
            </tr>
        }
        </tbody>
    </table>
</div>

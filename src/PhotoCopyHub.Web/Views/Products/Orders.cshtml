@model List<ProductOrder>
@{
    ViewData["Title"] = "Đơn văn phòng phẩm";
}

<div class="table-responsive">
    <table class="table table-striped bg-white">
        <thead>
        <tr>
            <th>Mã đơn</th>
            <th>Ngày tạo</th>
            <th>Tổng tiền</th>
            <th>Trạng thái</th>
            <th></th>
        </tr>
        </thead>
        <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Id</td>
                <td>@item.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</td>
                <td>@item.TotalAmount.ToString("N0")</td>
                <td><span class="badge @item.Status.ToBadgeClass()">@item.Status.GetDisplayName()</span></td>
                <td><a class="btn btn-sm btn-outline-primary" asp-action="Details" asp-route-id="@item.Id">Chi tiết</a></td>
            </tr>
        }
        </tbody>
    </table>
</div>

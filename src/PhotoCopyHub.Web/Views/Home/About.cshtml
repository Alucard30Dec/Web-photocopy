@{
    ViewData["Title"] = "Giới thiệu";
}

<section class="page-hero mb-4">
    <h2 class="mb-3">PhotoCopyHub</h2>
    <p class="mb-0">Nền tảng quản lý tiệm photocopy/in ấn dành cho cửa hàng nhỏ và vừa, tập trung vào vận hành ổn định, nghiệp vụ rõ ràng và dễ mở rộng theo nhu cầu thực tế.</p>
</section>

<div class="row g-3">
    <div class="col-md-6">
        <div class="card h-100">
            <div class="card-body">
                <h5 class="mb-3">Điểm mạnh cho khách hàng</h5>
                <ul class="mb-0">
                    <li>Tạo đơn in nhanh, theo dõi trạng thái minh bạch</li>
                    <li>Thanh toán bằng ví nội bộ, kiểm soát số dư dễ dàng</li>
                    <li>Quản lý lịch sử nạp tiền và giao dịch trực quan</li>
                </ul>
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card h-100">
            <div class="card-body">
                <h5 class="mb-3">Điểm mạnh cho quản trị</h5>
                <ul class="mb-0">
                    <li>Duyệt nạp tiền, điều chỉnh ví có lưu log đầy đủ</li>
                    <li>Quản lý bảng giá in, sản phẩm và dịch vụ hỗ trợ tập trung</li>
                    <li>Phân quyền chặt chẽ giữa Customer và Admin</li>
                </ul>
            </div>
        </div>
    </div>
</div>

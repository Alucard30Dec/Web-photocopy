@model DashboardViewModel
@{
    ViewData["Title"] = "Tổng quan";
}

<section class="page-hero mb-3">
    <div class="d-flex flex-column flex-xl-row justify-content-between align-items-xl-center gap-3">
        <div>
            <h3 class="mb-2">Xin chào, @User.Identity?.Name</h3>
            <p class="mb-0">Theo dõi số dư, đơn in và lịch sử giao dịch tập trung tại một nơi để thao tác nhanh khi cần.</p>
        </div>
        <div class="d-flex flex-wrap gap-2">
            <a class="btn btn-primary" asp-controller="PrintJobs" asp-action="Create">Tạo đơn in</a>
            <a class="btn btn-outline-secondary" asp-controller="Wallet" asp-action="TopUp">Nạp ví</a>
        </div>
    </div>
</section>

<div class="row g-3 mb-3">
    <div class="col-md-3">
        <div class="stat-card">
            <div class="stat-label">Số dư hiện tại</div>
            <div class="stat-value text-success">@Model.CurrentBalance.ToString("N0") đ</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="stat-card">
            <div class="stat-label">Yêu cầu nạp chờ duyệt</div>
            <div class="stat-value">@Model.PendingTopUpCount</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="stat-card">
            <div class="stat-label">Đơn in</div>
            <div class="stat-value">@Model.PrintJobsCount</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="stat-card">
            <div class="stat-label">Đơn văn phòng phẩm + hỗ trợ</div>
            <div class="stat-value">@(Model.ProductOrdersCount + Model.SupportOrdersCount)</div>
        </div>
    </div>
</div>

<div class="card">
    <div class="card-header">Giao dịch ví gần đây</div>
    <div class="table-responsive">
        <table class="table table-sm">
            <thead>
                <tr>
                    <th>Thời gian</th>
                    <th>Loại</th>
                    <th>Số tiền</th>
                    <th>Số dư sau GD</th>
                    <th>Ghi chú</th>
                </tr>
            </thead>
            <tbody>
            @if (Model.RecentTransactions.Count == 0)
            {
                <tr>
                    <td colspan="5" class="text-center text-muted py-4">Chưa có giao dịch nào.</td>
                </tr>
            }
            else
            {
                @foreach (var tx in Model.RecentTransactions)
                {
                    <tr>
                        <td>@tx.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</td>
                        <td>@tx.TransactionType.GetDisplayName()</td>
                        <td class="@(tx.Amount >= 0 ? "text-success" : "text-danger")">@tx.Amount.ToString("N0")</td>
                        <td>@tx.BalanceAfter.ToString("N0")</td>
                        <td>@tx.Note</td>
                    </tr>
                }
            }
            </tbody>
        </table>
    </div>
</div>

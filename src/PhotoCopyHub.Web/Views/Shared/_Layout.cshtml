<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - PhotoCopyHub</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:wght@400;500;600;700&family=Plus+Jakarta+Sans:wght@600;700;800&display=swap" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
@{
    var controller = ViewContext.RouteData.Values["controller"]?.ToString() ?? string.Empty;
    var action = ViewContext.RouteData.Values["action"]?.ToString() ?? string.Empty;
    var isAdmin = User.IsInRole("Admin");
    var isCustomer = User.IsInRole("Customer");
    var isShopOperator = User.IsInRole("ShopOperator");
}
<header class="site-header">
    <div class="site-ribbon">
        <div class="container-xl d-flex flex-wrap justify-content-between align-items-center gap-2">
            <span>Phục vụ nhanh tài liệu học tập, báo cáo, luận văn, tài liệu thi.</span>
            <span class="ribbon-highlight">Mở cửa 7:00 - 22:00 | Hỗ trợ in gấp trong giờ cao điểm</span>
        </div>
    </div>
    <nav class="navbar navbar-expand-lg navbar-dark site-navbar">
        <div class="container-xl">
            <a class="navbar-brand" asp-controller="Home" asp-action="Index">
                <span class="brand-dot"></span>
                <span>PhotoCopyHub</span>
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNavbar">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="mainNavbar">
                <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                    <li class="nav-item"><a class="nav-link @(controller == "Home" && action == "Index" ? "active" : string.Empty)" asp-controller="Home" asp-action="Index">Trang chủ</a></li>
                    <li class="nav-item"><a class="nav-link @(controller == "Home" && action == "Pricing" ? "active" : string.Empty)" asp-controller="Home" asp-action="Pricing">Bảng giá</a></li>
                    <li class="nav-item"><a class="nav-link @(controller == "Home" && action == "About" ? "active" : string.Empty)" asp-controller="Home" asp-action="About">Giới thiệu</a></li>

                    @if (User.Identity?.IsAuthenticated == true && (isCustomer || isAdmin))
                    {
                        <li class="nav-item"><a class="nav-link @(controller == "Dashboard" ? "active" : string.Empty)" asp-controller="Dashboard" asp-action="Index">Tổng quan</a></li>
                        <li class="nav-item"><a class="nav-link @(controller == "PrintJobs" ? "active" : string.Empty)" asp-controller="PrintJobs" asp-action="Index">Đơn in</a></li>
                        <li class="nav-item"><a class="nav-link @(controller == "Wallet" ? "active" : string.Empty)" asp-controller="Wallet" asp-action="Index">Ví</a></li>
                        <li class="nav-item"><a class="nav-link @(controller == "Products" ? "active" : string.Empty)" asp-controller="Products" asp-action="Index">Văn phòng phẩm</a></li>
                        <li class="nav-item"><a class="nav-link @(controller == "SupportOrders" ? "active" : string.Empty)" asp-controller="SupportOrders" asp-action="Create">Dịch vụ</a></li>
                    }
                </ul>

                <ul class="navbar-nav align-items-lg-center gap-lg-1">
                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        @if (isCustomer || isAdmin)
                        {
                            <li class="nav-item">
                                <a class="btn btn-sm btn-primary px-3 me-lg-1" asp-controller="PrintJobs" asp-action="Create">Tạo đơn in nhanh</a>
                            </li>
                        }

                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle user-nav-link" href="#" role="button" data-bs-toggle="dropdown">
                                @User.Identity.Name
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end">
                                <li><a class="dropdown-item @(controller == "Profile" ? "active" : string.Empty)" asp-controller="Profile" asp-action="Index">Hồ sơ</a></li>
                                @if (User.Identity?.IsAuthenticated == true && (isShopOperator || isAdmin))
                                {
                                    <li><a class="dropdown-item" asp-area="Shop" asp-controller="Dashboard" asp-action="Index">Khu vận hành tiệm</a></li>
                                }
                                @if (isAdmin)
                                {
                                    <li><a class="dropdown-item" asp-area="Admin" asp-controller="Dashboard" asp-action="Index">Khu quản trị</a></li>
                                }
                                <li><hr class="dropdown-divider" /></li>
                                <li>
                                    <form asp-controller="Account" asp-action="Logout" method="post">
                                        <button class="dropdown-item" type="submit">Đăng xuất</button>
                                    </form>
                                </li>
                            </ul>
                        </li>
                    }
                    else
                    {
                        <li class="nav-item"><a class="nav-link @(controller == "Account" && action == "Login" ? "active" : string.Empty)" asp-controller="Account" asp-action="Login">Đăng nhập</a></li>
                        <li class="nav-item"><a class="btn btn-sm btn-light rounded-pill px-3" asp-controller="Account" asp-action="Register">Tạo tài khoản</a></li>
                    }
                </ul>
            </div>
        </div>
    </nav>
</header>

<main class="container-xl site-main">
    <partial name="_Alert" />
    @RenderBody()
</main>

<footer class="site-footer py-3">
    <div class="container-xl d-flex flex-column flex-md-row justify-content-between gap-2">
        <span>&copy; @DateTime.Now.Year - PhotoCopyHub</span>
        <span>Nền tảng vận hành tiệm photocopy hiện đại cho khách hàng Việt Nam</span>
    </div>
</footer>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>

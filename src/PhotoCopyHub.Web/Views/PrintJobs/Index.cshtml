@model List<PrintJob>
@{
    ViewData["Title"] = "Đơn in của tôi";
}

<section class="page-hero mb-3">
    <div class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-center gap-3">
        <div>
            <h3 class="mb-1">Đơn in của tôi</h3>
            <p class="mb-2">Theo dõi toàn bộ đơn in và trạng thái xử lý theo thời gian thực.</p>
            <div class="info-chip-group">
                <span class="info-chip">Tổng đơn: @Model.Count</span>
                <span class="info-chip">Đang in: @Model.Count(x => x.Status == PrintJobStatus.Processing)</span>
                <span class="info-chip">Sẵn sàng nhận: @Model.Count(x => x.Status == PrintJobStatus.ReadyForPickup)</span>
            </div>
        </div>
        <div class="d-flex flex-wrap gap-2">
            <a class="btn btn-primary" asp-action="Create">Tạo đơn in mới</a>
            <a class="btn btn-outline-secondary" asp-action="Files">File đã upload</a>
        </div>
    </div>
</section>

<div class="table-responsive">
    <table class="table table-striped bg-white">
        <thead>
            <tr>
                <th>Mã đơn</th>
                <th>Ngày tạo</th>
                <th>Tổng tiền</th>
                <th>Trạng thái</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
        @if (Model.Count == 0)
        {
            <tr>
                <td colspan="5" class="text-center text-muted py-4">Bạn chưa có đơn in nào.</td>
            </tr>
        }
        else
        {
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.Id</td>
                    <td>@item.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</td>
                    <td>@item.TotalAmount.ToString("N0")</td>
                    <td><span class="badge @item.Status.ToBadgeClass()">@item.Status.GetDisplayName()</span></td>
                    <td>
                        <div class="d-flex flex-wrap gap-2">
                            <a class="btn btn-sm btn-outline-primary" asp-action="Details" asp-route-id="@item.Id">Chi tiết</a>
                        </div>
                    </td>
                </tr>
            }
        }
        </tbody>
    </table>
</div>

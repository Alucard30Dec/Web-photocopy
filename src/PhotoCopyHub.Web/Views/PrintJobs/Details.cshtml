@model PrintJob
@{
    ViewData["Title"] = "Chi tiết đơn in";
}

<section class="page-hero mb-3">
    <h3 class="mb-2">Chi tiết đơn in</h3>
    <p class="mb-0">Mã đơn: <strong>@Model.Id</strong></p>
</section>

<div class="row g-3">
    <div class="col-lg-8">
        <div class="card">
            <div class="card-body">
                <dl class="row mb-0">
                    <dt class="col-sm-4">Trạng thái</dt>
                    <dd class="col-sm-8"><span class="badge @Model.Status.ToBadgeClass()">@Model.Status.GetDisplayName()</span></dd>

                    <dt class="col-sm-4">Khổ giấy</dt>
                    <dd class="col-sm-8">@Model.PaperSize.GetDisplayName()</dd>

                    <dt class="col-sm-4">Kiểu in</dt>
                    <dd class="col-sm-8">@Model.PrintSide.GetDisplayName() - @Model.ColorMode.GetDisplayName()</dd>

                    <dt class="col-sm-4">Số bản / trang</dt>
                    <dd class="col-sm-8">@Model.Copies / @Model.TotalPages</dd>

                    <dt class="col-sm-4">Tổng trang cần in</dt>
                    <dd class="col-sm-8">@(Model.Copies * Model.TotalPages)</dd>

                    <dt class="col-sm-4">Tổng tiền</dt>
                    <dd class="col-sm-8 fw-semibold">@Model.TotalAmount.ToString("N0") đ</dd>

                    <dt class="col-sm-4">Hình thức nhận</dt>
                    <dd class="col-sm-8">@Model.DeliveryMethod.GetDisplayName()</dd>

                    <dt class="col-sm-4">Địa chỉ giao</dt>
                    <dd class="col-sm-8">@(string.IsNullOrWhiteSpace(Model.DeliveryAddress) ? "Nhận tại tiệm" : Model.DeliveryAddress)</dd>

                    <dt class="col-sm-4">Ghi chú</dt>
                    <dd class="col-sm-8">@(string.IsNullOrWhiteSpace(Model.Notes) ? "Không có ghi chú." : Model.Notes)</dd>
                </dl>
            </div>
        </div>
    </div>

    <div class="col-lg-4">
        <div class="card">
            <div class="card-body">
                <h5 class="card-title mb-2">Mốc thời gian</h5>
                <div class="summary-line">
                    <span>Tạo đơn</span>
                    <span class="summary-value">@Model.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</span>
                </div>
                <div class="summary-line">
                    <span>Cập nhật gần nhất</span>
                    <span class="summary-value">@((Model.UpdatedAt ?? Model.CreatedAt).ToLocalTime().ToString("dd/MM/yyyy HH:mm"))</span>
                </div>
            </div>
        </div>

        <div class="card mt-3">
            <div class="card-body">
                <h5 class="card-title mb-2">File đơn in</h5>
                <p class="text-muted small mb-3">Bản xem trước được hiển thị tự động bên dưới.</p>
                <iframe
                    src="@Url.Action("PreviewFile", new { id = Model.UploadedFileId })"
                    title="Xem trước file đơn in @Model.Id"
                    class="w-100 border rounded bg-light mb-3"
                    style="height: 420px;"
                    loading="lazy">
                </iframe>
                <div>
                    <a class="btn btn-outline-secondary" asp-action="DownloadFile" asp-route-id="@Model.UploadedFileId">Tải file</a>
                </div>
            </div>
        </div>
    </div>
</div>
